# =============================================================================
# Netmap NG Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables can also be set as system environment variables.

# --- App -------------------------------------------------------------------

# REQUIRED: Session signing key (minimum 16 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=

# Public URL of the backend (used for OAuth callbacks and secure cookie detection)
APP_BASE_URL=http://localhost:8000

# Set to true ONLY for local development without OIDC authentication
AUTH_DISABLED=false

# CORS origins (comma-separated). Add your frontend URL here.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLAlchemy database URL for map storage (default: SQLite in current directory)
APP_DB_URL=sqlite+aiosqlite:///./netmap.db

# --- OIDC Authentication ---------------------------------------------------
# Configure your identity provider below. Examples for common providers:
#
# Microsoft Entra ID (Azure AD):
#   OAUTH_AUTHORIZE_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
#   OAUTH_TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
#   OAUTH_USERINFO_URL=https://graph.microsoft.com/oidc/userinfo
#   OAUTH_SCOPES=openid profile email
#   OAUTH_ROLES_CLAIM=roles
#
# Keycloak:
#   OAUTH_AUTHORIZE_URL=https://keycloak.example.com/realms/<realm>/protocol/openid-connect/auth
#   OAUTH_TOKEN_URL=https://keycloak.example.com/realms/<realm>/protocol/openid-connect/token
#   OAUTH_USERINFO_URL=https://keycloak.example.com/realms/<realm>/protocol/openid-connect/userinfo
#   OAUTH_SCOPES=openid profile email
#   OAUTH_ROLES_CLAIM=realm_access.roles

# OIDC client credentials from your identity provider
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# OIDC endpoints (provider-specific, see examples above)
OAUTH_AUTHORIZE_URL=https://idp.example.com/authorize
OAUTH_TOKEN_URL=https://idp.example.com/token
OAUTH_USERINFO_URL=https://idp.example.com/userinfo

# OIDC scopes to request
OAUTH_SCOPES=openid profile email

# --- OIDC Roles (optional) -------------------------------------------------
# Role-based access control via OIDC claims.
# Leave OAUTH_EDITOR_ROLE empty to allow all authenticated users to edit.
# Leave OAUTH_ADMIN_ROLE empty for no admin role enforcement.

# Role claim value required for editor access (create/edit maps)
OAUTH_EDITOR_ROLE=

# Role claim value required for admin access (manage all maps)
OAUTH_ADMIN_ROLE=

# Name of the claim in the OIDC token that contains user roles
# For Entra ID: "roles"
# For Keycloak: "realm_access.roles" or a custom mapper
OAUTH_ROLES_CLAIM=roles

# --- Observium MySQL (read-only) -------------------------------------------
# Connection to your Observium database for live traffic data.
# Create a read-only user: see README.md for the SQL commands.

OBSERVIUM_DB_HOST=observium.local
OBSERVIUM_DB_PORT=3306
OBSERVIUM_DB_USER=netmap_ro
OBSERVIUM_DB_PASSWORD=
OBSERVIUM_DB_NAME=observium

# --- Observium RRD path ----------------------------------------------------
# Path to Observium's RRD files for historical traffic graphs.
# In Docker: mount the directory and set the container path (e.g., /rrd).
# Native install: use the actual path on the server (e.g., /opt/observium/rrd).

OBSERVIUM_RRD_PATH=/opt/observium/rrd
