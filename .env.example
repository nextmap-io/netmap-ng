# --- App ---
# REQUIRED: Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`
APP_SECRET_KEY=
APP_BASE_URL=http://localhost:8000

# Set to true ONLY for local development without OAuth
AUTH_DISABLED=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- OAuth2 (example with Generic OIDC) ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZE_URL=https://idp.example.com/authorize
OAUTH_TOKEN_URL=https://idp.example.com/token
OAUTH_USERINFO_URL=https://idp.example.com/userinfo
OAUTH_SCOPES=openid profile email

# --- Observium MySQL (read-only) ---
OBSERVIUM_DB_HOST=observium.local
OBSERVIUM_DB_PORT=3306
OBSERVIUM_DB_USER=netmap_ro
OBSERVIUM_DB_PASSWORD=
OBSERVIUM_DB_NAME=observium

# --- Observium RRD path (if mounted / accessible) ---
OBSERVIUM_RRD_PATH=/opt/observium/rrd

# --- Observium API (optional, Subscription Edition only) ---
OBSERVIUM_API_URL=
OBSERVIUM_API_USER=
OBSERVIUM_API_PASSWORD=

# --- Claude API (for AI-assisted layout) ---
ANTHROPIC_API_KEY=

# --- App database ---
APP_DB_URL=sqlite+aiosqlite:///./netmap.db
